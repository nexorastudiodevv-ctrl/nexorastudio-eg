/* Nexora Studio EG — Premium Agency Style */

:root{
  --bg0:#050816;
  --bg1:#0b1226;
  --card:rgba(255,255,255,.06);
  --card2:rgba(255,255,255,.09);
  --stroke:rgba(255,255,255,.12);
  --text:rgba(255,255,255,.92);
  --muted:rgba(226,232,240,.78);
  --muted2:rgba(226,232,240,.62);
  --cyan:#22d3ee;
  --blue:#60a5fa;
  --accent:linear-gradient(135deg, var(--blue), var(--cyan));
  --accent2:linear-gradient(135deg, rgba(96,165,250,.95), rgba(34,211,238,.95));
  --shadow: 0 25px 70px rgba(0,0,0,.45);
  --shadow2: 0 12px 40px rgba(0,0,0,.35);
  --radius:18px;
  --radius2:24px;
}

*{box-sizing:border-box; margin:0; padding:0;}
html{scroll-behavior:smooth;}
body{
  font-family:"Poppins", system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
  background: radial-gradient(1200px 800px at 15% 10%, rgba(34,211,238,.15), transparent 55%),
              radial-gradient(900px 600px at 80% 0%, rgba(96,165,250,.18), transparent 60%),
              linear-gradient(180deg, var(--bg0), var(--bg1));
  color:var(--text);
  line-height:1.7;
}

/* Prevent horizontal swipe/scroll artifacts on mobile */
html, body {
  width: 100%;
  height: 100%;
  max-width: 100%;
  overflow-x: hidden;
  overscroll-behavior-x: none;
}

/* Avoid accidental overflow caused by absolute/fixed/animated elements */
img, video, canvas, svg { max-width: 100%; height: auto; }

/* Hard stop for any element that tries to exceed the viewport */
* { max-width: 100%; }

/* Extra guard against horizontal overflow on mobile (especially with fixed/animated elements) */
html { overflow-x: hidden; }
body { overflow-x: hidden; }

/* Prevent layout shifts from transforms from creating an overflow viewport */
body { position: relative; }

/* Ensure main container/content doesn't force wider layout */
#main { width: 100%; max-width: 100%; }





a{color:inherit; text-decoration:none;}
img{max-width:100%; display:block;}

.container{width:92%; max-width:1200px; margin:0 auto;}

.skip-link{
  position:absolute; left:-9999px; top:auto; width:1px; height:1px; overflow:hidden;
}
.skip-link:focus{
  left:16px; top:16px; width:auto; height:auto; padding:10px 12px;
  background:rgba(0,0,0,.7); border:1px solid var(--stroke); border-radius:12px;
  z-index:9999;
}

/* Topbar */
.topbar{
  position:sticky; top:0; z-index:50;
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
  background: rgba(5,8,22,.55);
  border-bottom: 1px solid rgba(255,255,255,.08);
}
.topbar__inner{
  display:flex; align-items:center; justify-content:space-between;
  padding:14px 0;
}
.brand{display:flex; align-items:center; gap:12px;}
.brand__mark{
  /* Outer circle mark (CSS-only logo) */
  width:clamp(40px, 4.2vw, 46px);
  height:clamp(40px, 4.2vw, 46px);
  border-radius:999px;

  position:relative;
  display:grid;
  place-items:center;

  /* Base glow layers */
  background:
    radial-gradient(circle at 30% 25%, rgba(34,211,238,.40), rgba(34,211,238,0) 50%),
    radial-gradient(circle at 70% 75%, rgba(96,165,250,.30), rgba(96,165,250,0) 55%),
    linear-gradient(135deg, rgba(96,165,250,.25), rgba(34,211,238,.22));

  box-shadow:
    0 0 0 1px rgba(34,211,238,.35),
    0 0 18px rgba(34,211,238,.22),
    0 0 42px rgba(96,165,250,.14),
    0 14px 40px rgba(0,0,0,.35);
}

.brand__mark::before{
  content:"";
  position:absolute;
  inset:-1px;
  border-radius:999px;
  background:
    conic-gradient(from 210deg,
      rgba(34,211,238,.85),
      rgba(96,165,250,.85),
      rgba(34,211,238,.85)
    );
  opacity:.20;
  filter: blur(1px);
  pointer-events:none;
}

.brand__mark::after{
  /* Subtle digital scanline */
  content:"";
  position:absolute;
  inset:0;
  border-radius:999px;
  background:
    repeating-linear-gradient(
      180deg,
      rgba(255,255,255,.00) 0px,
      rgba(255,255,255,.03) 2px,
      rgba(255,255,255,.00) 5px
    );
  mix-blend-mode: screen;
  opacity:.25;
  pointer-events:none;
}

.brand__logo{
  position:relative;
  width:78%;
  height:78%;
  display:grid;
  place-items:center;
}

.brand__logoText{
  position:relative;
  font-weight:900;
  letter-spacing:-.12em;
  font-size:clamp(14px, 2.0vw, 16px);
  line-height:1;
  color: rgba(235,255,255,.95);

  /* Neon cyan/blue text glow */
  text-shadow:
    0 0 6px rgba(34,211,238,.55),
    0 0 18px rgba(96,165,250,.35);
}

/* Fake grid overlay to resemble futuristic logo */
.brand__logoGrid{
  position:absolute;
  inset:-8%;
  border-radius:999px;
  background:
    radial-gradient(circle at 50% 50%, rgba(34,211,238,.22), rgba(34,211,238,0) 62%),
    repeating-linear-gradient(90deg, rgba(34,211,238,.18) 0 1px, transparent 1px 10px),
    repeating-linear-gradient(0deg, rgba(96,165,250,.14) 0 1px, transparent 1px 10px);
  opacity:.45;
  filter: blur(.15px);
  pointer-events:none;
}

.brand__name{font-weight:700; letter-spacing:.2px;}


.nav{display:flex; gap:22px; align-items:center;}
.nav a{
  color:var(--muted);
  font-weight:500;
  font-size:14px;
  padding:10px 12px;
  border-radius:12px;
  transition:.2s;
}
.nav a:hover{color:var(--text); background:rgba(255,255,255,.06);}

.icon-btn{
  width:44px; height:44px; border-radius:14px;
  border:1px solid var(--stroke);
  background:rgba(255,255,255,.05);
  color:var(--text);
  display:grid; place-items:center;
  cursor:pointer;
}

.mobile-only{display:none;}

.mobile-menu{display:none;}
.mobile-menu.open{display:block;}
.mobile-menu__panel{
  margin:0 auto;
  width:92%; max-width:520px;
  padding:14px 0 20px;
}
.mobile-menu__links{
  border:1px solid var(--stroke);
  background:rgba(5,8,22,.6);
  border-radius:18px;
  padding:10px;
}
.mobile-menu__links a{
  display:block;
  padding:12px 14px;
  color:var(--muted);
  font-weight:600;
  border-radius:14px;
}
.mobile-menu__links a:hover{background:rgba(255,255,255,.06); color:var(--text);}

/* Buttons */
.btn{
  display:inline-flex; align-items:center; gap:10px;
  padding:14px 18px;
  border-radius:16px;
  border:1px solid transparent;
  font-weight:700;
  font-size:14px;
  cursor:pointer;
  transition: .25s;
  user-select:none;
  -webkit-user-select:none;
}
.btn i{font-size:15px;}

.btn--primary{
  background: var(--accent2);
  box-shadow: 0 18px 50px rgba(34,211,238,.18);
}
.btn--primary:hover{transform: translateY(-2px); filter:saturate(1.1);}

.btn--ghost{
  background: rgba(255,255,255,.05);
  border-color: rgba(255,255,255,.14);
  color: var(--text);
}
.btn--ghost:hover{transform: translateY(-2px); background: rgba(255,255,255,.08);}

.mt-16{margin-top:16px;}
.mt-24{margin-top:24px;}

/* Typography */
.h1{font-size:52px; line-height:1.05; letter-spacing:-.8px;}
.h2{font-size:28px; letter-spacing:-.3px; line-height:1.2;}
.h3{font-size:18px;}
.lead{font-size:16px; color:var(--muted); max-width:58ch;}
.muted{color:var(--muted);}
.small{font-size:13px; color:var(--muted2);}

.badge{
  display:inline-flex; align-items:center; gap:10px;
  padding:10px 14px;
  border-radius:999px;
  background: rgba(255,255,255,.06);
  border: 1px solid rgba(255,255,255,.12);
  color: rgba(255,255,255,.92);
  font-weight:700;
  font-size:13px;
  width:fit-content;
}

/* Glass */
.glass{
  background: rgba(255,255,255,.06);
  border: 1px solid rgba(255,255,255,.12);
  border-radius: var(--radius);
  box-shadow: var(--shadow2);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
}

.p-24{padding:24px;}

/* Reveal */
.reveal{
  opacity:0;
  transform: translateY(16px);
  transition: .7s cubic-bezier(.2,.9,.2,1);
}
.reveal.in-view{opacity:1; transform:translateY(0);}

/* Hero */
.hero{
  position:relative;
  padding: 60px 0 30px;
}
.hero__inner{position:relative; z-index:1;}
.hero__grid{display:grid; grid-template-columns: 1.2fr .9fr; gap:28px; align-items:center;}

.bg-shapes{position:absolute; inset:0; z-index:0; pointer-events:none; overflow:hidden; contain:layout paint;}
.shape{

  position:absolute;
  width:240px; height:240px;
  border-radius: 999px;
  background: radial-gradient(circle at 30% 30%, rgba(34,211,238,.35), transparent 60%);
  filter: blur(2px);
  opacity:.55;
  animation: floaty 10s ease-in-out infinite;
}
.s1{left:-70px; top:-40px;}
.s2{right:-90px; top:30px; width:300px; height:300px; background: radial-gradient(circle at 30% 30%, rgba(96,165,250,.35), transparent 60%);} 
.s3{left:20%; bottom:-120px; width:260px; height:260px; background: radial-gradient(circle at 30% 30%, rgba(34,211,238,.25), transparent 60%);} 
.s4{right:20%; bottom:-160px; width:200px; height:200px; background: radial-gradient(circle at 30% 30%, rgba(96,165,250,.25), transparent 60%);} 

@keyframes floaty{
  0%,100%{transform: translateY(0) translateX(0) scale(1);}
  50%{transform: translateY(-18px) translateX(10px) scale(1.03);}
}

.hero__cta{display:flex; gap:14px; flex-wrap:wrap; margin-top:20px;}
.hero__chips{display:flex; gap:10px; flex-wrap:wrap; margin-top:18px;}
.chip{
  padding:10px 12px;
  border-radius:999px;
  border:1px solid rgba(255,255,255,.12);
  background: rgba(255,255,255,.05);
  color: var(--muted);
  font-weight:600;
  font-size:13px;
}
.chip i{color: rgba(34,211,238,.9);}

/* Phone mock */
.phone-mock{padding:16px;}
.phone-mock__top{display:flex; align-items:center; justify-content:space-between; gap:10px; padding:6px 6px 12px;}
.dots{display:flex; gap:6px;}
.dots span{width:8px; height:8px; border-radius:50%; background:rgba(255,255,255,.22);}
.pill{padding:8px 12px; border-radius:999px; border:1px solid rgba(255,255,255,.12); background: rgba(255,255,255,.05); font-weight:700; font-size:13px; color: rgba(255,255,255,.9);}
.pill--cyan{border-color: rgba(34,211,238,.35); background: rgba(34,211,238,.10);}

.phone-mock__screen{display:grid; gap:10px; padding:8px; border-radius:16px; background: rgba(0,0,0,.18); border:1px solid rgba(255,255,255,.08);} 
.mini-card{display:flex; gap:12px; align-items:center; padding:12px; border-radius:16px; background: rgba(255,255,255,.06); border:1px solid rgba(255,255,255,.10);}
.mini-card i{font-size:18px; color: rgba(34,211,238,.95);} 
.mini-card b{display:block; font-size:14px;}
.mini-card span{display:block; font-size:12px; color:var(--muted2); margin-top:2px;}

.floating{position:relative; margin-top:18px;}
.float-item{
  position:absolute; width:46px; height:46px; border-radius:16px;
  display:grid; place-items:center;
  background: rgba(255,255,255,.06);
  border:1px solid rgba(255,255,255,.12);
  backdrop-filter: blur(12px);
  box-shadow: 0 16px 50px rgba(0,0,0,.35);
  animation: pop 6s ease-in-out infinite;
}
.f1{left:-6px; top:-10px; animation-delay:0s;}
.f2{right:-10px; top:20px; animation-delay:1s;}
.f3{left:20px; bottom:-6px; animation-delay:2s;}
@keyframes pop{0%,100%{transform: translateY(0);}50%{transform: translateY(-10px);}}
.float-item i{color: rgba(96,165,250,.95);}

/* Sections */
.section{padding:72px 0;}
.section--alt{background: rgba(255,255,255,.02); border-top:1px solid rgba(255,255,255,.06); border-bottom:1px solid rgba(255,255,255,.06);} 

.section-head{display:flex; flex-direction:column; gap:10px; margin-bottom:24px;}

.grid-2{display:grid; grid-template-columns: 1fr 1fr; gap:22px;}
.grid-3{display:grid; grid-template-columns: repeat(3, 1fr); gap:18px;}

.icon-circle{
  width:48px; height:48px; border-radius:18px;
  display:grid; place-items:center;
  background: rgba(255,255,255,.06);
  border:1px solid rgba(255,255,255,.12);
  color: rgba(34,211,238,.95);
  margin-bottom:14px;
}

.tags{display:flex; gap:10px; flex-wrap:wrap; margin-top:12px;}
.tag{display:inline-flex; gap:8px; align-items:center; padding:10px 12px; border-radius:999px; background: rgba(255,255,255,.05); border:1px solid rgba(255,255,255,.12); color:var(--muted); font-weight:700; font-size:13px;}

.divider{height:1px; background: rgba(255,255,255,.10); margin:16px 0;}

.cta-row{display:flex; align-items:center; justify-content:space-between; gap:14px; flex-wrap:wrap;}

.stats{display:grid; grid-template-columns: repeat(4, 1fr); gap:14px;}
.stat{padding:14px 12px; border-radius:16px; background: rgba(255,255,255,.04); border:1px solid rgba(255,255,255,.10);} 
.stat__num{font-weight:900; font-size:22px; color: rgba(255,255,255,.95);}
.stat__label{color:var(--muted2); font-weight:600; font-size:13px; margin-top:6px;}

/* Product */
.product__title{display:flex; gap:14px; align-items:center;}
.product__logo{width:52px; height:52px; border-radius:20px; background: rgba(34,211,238,.12); border:1px solid rgba(34,211,238,.35); display:grid; place-items:center; color: rgba(34,211,238,.95);} 

.features{margin-top:18px; display:grid; gap:10px;}
.feature{padding:12px; border-radius:16px; background: rgba(255,255,255,.04); border:1px solid rgba(255,255,255,.10); display:flex; gap:12px; align-items:center; color:var(--muted); font-weight:700;}
.feature i{color: rgba(96,165,250,.95);} 

.mock-large{padding:18px;}
.mock-large__header{display:flex; align-items:center; justify-content:space-between; gap:14px; padding:4px 4px 14px;}
.mock-large__chart{height:170px; display:flex; gap:10px; align-items:flex-end; padding:8px; border-radius:18px; background: rgba(0,0,0,.16); border:1px solid rgba(255,255,255,.08);} 
.bar{flex:1; border-radius:14px; background: rgba(255,255,255,.06); border:1px solid rgba(255,255,255,.08); position:relative; overflow:hidden;}
.bar::after{content:""; position:absolute; inset:auto 0 0 0; height:70%; background: linear-gradient(180deg, rgba(34,211,238,.85), rgba(96,165,250,.55));}
.b1{height:45%;}.b2{height:70%;}.b3{height:55%;}.b4{height:85%;}.b5{height:62%;}

.mock-large__cards{margin-top:14px; display:grid; grid-template-columns: repeat(3, 1fr); gap:10px;}
.mini-stat{padding:12px; border-radius:16px; background: rgba(255,255,255,.04); border:1px solid rgba(255,255,255,.10);} 
.mini-stat b{display:block; font-size:13px; color: rgba(255,255,255,.95);} 
.mini-stat span{display:block; margin-top:6px; color:var(--muted2); font-weight:700; font-size:13px;}

/* App Screenshots */
.app-screens{display:grid; grid-template-columns: repeat(2, 1fr); gap:16px;}
.app-screen{margin:0; padding:0; overflow:hidden; border-radius:var(--radius2); border:1px solid rgba(255,255,255,.10); background: rgba(255,255,255,.03); box-shadow: var(--shadow2);}
.app-screen__media{aspect-ratio: 9 / 16; background: rgba(0,0,0,.18);}
.app-screen__media img{width:100%; height:100%; object-fit:cover;}
.app-screen__caption{padding:14px 14px 16px; display:flex; flex-direction:column; gap:6px;}
.app-screen__caption b{color: rgba(255,255,255,.95);}
.app-screen__caption span{color: var(--muted2); font-weight:700; font-size:13px;}

/* Portfolio */
.portfolio-card{overflow:hidden; transition:.3s;}
.portfolio-card:hover{transform: translateY(-6px); border-color: rgba(34,211,238,.28);} 
.portfolio-card__media{
  height:150px;
  border-radius:16px;
  border:1px solid rgba(255,255,255,.10);
  background:
    radial-gradient(220px 120px at 20% 30%, rgba(34,211,238,.25), transparent 60%),
    radial-gradient(200px 140px at 80% 10%, rgba(96,165,250,.22), transparent 60%),
    rgba(255,255,255,.04);
  position:relative;
}
.media-pill{position:absolute; left:14px; top:14px; padding:10px 12px; border-radius:999px; background: rgba(0,0,0,.18); border:1px solid rgba(255,255,255,.12); font-weight:800; color: rgba(255,255,255,.92); font-size:13px;}
.portfolio-card__body{padding:16px 6px 6px;}
.portfolio-card__actions{margin-top:12px;}
.link-btn{display:inline-flex; gap:10px; align-items:center; font-weight:800; color: rgba(34,211,238,.95);} 
.link-btn i{transition:.2s;}
.portfolio-card:hover .link-btn i{transform: translateX(3px);} 

/* Article card (list view) */
.article-card{overflow:hidden; border-radius:18px; display:flex; flex-direction:column; transition:.28s;}
.article-card:hover{transform:translateY(-6px);}
.article-card__media{width:100%; height:180px; object-fit:cover; display:block; border-top-left-radius:18px; border-top-right-radius:18px;}
.article-card__body{padding:18px; display:flex; flex-direction:column; gap:10px;}
.article-card__title{font-size:20px; line-height:1.15; color:var(--text);}
.article-card__excerpt{color:var(--muted); max-height:4.8em; overflow:hidden;}
.article-card__footer{margin-top:auto;}


/* Tech */
.tech-rail{display:flex; flex-wrap:wrap; gap:12px; align-items:center; justify-content:space-between;}
.tech{display:inline-flex; gap:10px; align-items:center; padding:12px 14px; border-radius:999px; border:1px solid rgba(255,255,255,.12); background: rgba(255,255,255,.05); color:var(--muted); font-weight:800; font-size:13px;}
.tech i{color: rgba(96,165,250,.95);} 

/* FAQ */
.faq{max-width:820px; margin:0 auto;}
.accordion{border-radius:16px; border:1px solid rgba(255,255,255,.10); background: rgba(255,255,255,.04); padding:0; overflow:hidden;}
.accordion + .accordion{margin-top:12px;}
.accordion__btn{
  width:100%;
  display:flex; align-items:center; justify-content:space-between;
  padding:16px;
  background: transparent;
  border:0;
  cursor:pointer;
  color: rgba(255,255,255,.92);
  font-weight:800;
}
.accordion__btn i{color: rgba(34,211,238,.95);}
.accordion__content{
  max-height:0;
  overflow:hidden;
  transition: .35s ease;
}
.accordion.open{border-color: rgba(34,211,238,.25);}
.accordion.open .accordion__content{
  max-height: 180px;
  padding:0 16px 16px;
}

/* Contact */
.contact-list{display:grid; gap:14px; margin-top:14px;}
.contact-item{display:flex; gap:12px; align-items:flex-start; color:var(--muted); font-weight:700;}
.contact-item i{color: rgba(34,211,238,.95); margin-top:2px;}
.contact-item a{color: rgba(255,255,255,.92); text-decoration:underline; text-decoration-color: rgba(34,211,238,.35);}

.form{display:grid; gap:12px;}
label span{display:block; font-weight:800; font-size:13px; color: rgba(255,255,255,.9); margin:8px 0;}
input, textarea{
  width:100%;
  padding:14px 14px;
  border-radius:16px;
  border:1px solid rgba(255,255,255,.12);
  background: rgba(0,0,0,.16);
  color: var(--text);
  outline:none;
}
input:focus, textarea:focus{border-color: rgba(34,211,238,.35); box-shadow: 0 0 0 4px rgba(34,211,238,.12);} 

.map-placeholder{
  margin-top:18px;
  border-radius:18px;
  border:1px dashed rgba(255,255,255,.18);
  background: rgba(255,255,255,.03);
  padding:18px;
}
.map-placeholder__inner{display:flex; align-items:center; gap:14px; justify-content:center;}
.map-placeholder i{font-size:22px; color: rgba(96,165,250,.95);} 

/* Footer */
.footer{padding:34px 0 22px; border-top:1px solid rgba(255,255,255,.07); background: rgba(0,0,0,.10);} 
.footer__inner{display:grid; grid-template-columns: 1.2fr .8fr .8fr; gap:18px; align-items:start;}
.footer__brand{display:flex; gap:12px; align-items:center; font-weight:900;}
.footer__links{display:flex; gap:14px; flex-wrap:wrap; justify-content:flex-start; margin-top:8px;}
.footer__links a{color:var(--muted); font-weight:700;}
.footer__links a:hover{color:var(--text); text-decoration:underline; text-decoration-color: rgba(34,211,238,.4);} 
.footer__social{display:flex; gap:12px; justify-content:flex-end;}
.footer__social a{width:44px; height:44px; border-radius:16px; display:grid; place-items:center; border:1px solid rgba(255,255,255,.12); background: rgba(255,255,255,.04);} 
.footer__social a i{color: rgba(34,211,238,.95);} 
.footer__bottom{margin-top:16px; color:var(--muted2); font-weight:600; font-size:13px; display:flex; justify-content:center;}

/* Error */
.error-wrap{max-width:720px; margin:0 auto; text-align:center;}
.error-icon{width:66px; height:66px; border-radius:26px; margin:0 auto 10px; display:grid; place-items:center; background: rgba(34,211,238,.10); border:1px solid rgba(34,211,238,.35); color: rgba(34,211,238,.95);} 

/* Responsive */
@media (max-width: 980px){
  .hero__grid{grid-template-columns: 1fr;}
  .grid-3{grid-template-columns: 1fr;}
  .grid-2{grid-template-columns: 1fr;}
  .stats{grid-template-columns: repeat(2, 1fr);}
  .footer__inner{grid-template-columns: 1fr;}
  .footer__social{justify-content:flex-start;}
  .nav{display:none;}
  .mobile-only{display:grid;}
}

@media (max-width: 520px){
  .h1{font-size:38px;}
  .h2{font-size:24px;}
  .stats{grid-template-columns: 1fr;}

  /* Prevent absolute decorative elements from creating horizontal overflow */
  .s1{left:-10px;}
  .s2{right:-10px;}
  .s3{left:0; bottom:-90px;}
  .s4{right:0; bottom:-110px;}

  .float-item{display:none;}
}


